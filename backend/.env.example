# AI Marketplace Assistant - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# Application Settings
# ============================================
APP_NAME=AI Marketplace Assistant
APP_VERSION=0.1.0
DEBUG=False

# ============================================
# API Settings
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ============================================
# Database Settings (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://username:password@localhost:5432/ai_marketplace
DATABASE_ECHO=False
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ============================================
# Redis Settings
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# ============================================
# Celery Settings (Task Queue)
# ============================================
# If not set, will use REDIS_URL as default
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# Logging Settings
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================
# AI Service Settings
# ============================================
# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek API Key (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ============================================
# Wildberries API Settings
# ============================================
WB_API_KEY=your-wildberries-api-key-here
WB_API_URL=https://suppliers-api.wildberries.ru

# ============================================
# Security Settings
# ============================================
# Generate a secure random string for SECRET_KEY
# Example: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_ALLOW_ALL=True
AUTH_TEST_TOKEN=dev-test-token

# ============================================
# Automation Settings (Stage 11)
# ============================================
AUTOMATION_ENABLED=True
AUTOMATION_EXECUTE_ACTIONS=False
AUTOMATION_SALES_DROP_THRESHOLD_PCT=25
AUTOMATION_LOW_STOCK_THRESHOLD=10
